{
  "name": "NanoGPT Browser Assistant",
  "version": "1.0.13",
  "description": "Use NanoGPT on webpages to summarize, explain, translate, and chat with page context.",
  "icons": {
    "16": "icons/16.png",
    "32": "icons/32.png",
    "48": "icons/48.png",
    "128": "icons/128.png"
  },
  "manifest_version": 2,
  "permissions": ["scripting", "activeTab", "storage", "contextMenus", "<all_urls>"],
  "background": {
    "scripts": ["browser-polyfill.min.js", "shared/background-utils.js", "background.js"]
  },
  "commands": {
    "toggle-search-bar": {
      "suggested_key": {
        "windows": "Ctrl+Alt+S",
        "linux": "Alt+S",
        "mac": "Alt+S"
      },
      "description": "Toggle NanoGPT Browser Assistant"
    }
  },
  "web_accessible_resources": ["logo.png"],
  "sidebar_action": {
    "default_title": "NanoGPT Browser Assistant",
    "default_panel": "sidebar.html",
    "default_icon": {
      "16": "icons/16.png",
      "32": "icons/32.png",
      "48": "icons/48.png",
      "128": "icons/128.png"
    }
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "nanogpt-search@nano-gpt.com"
    }
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "css": ["overlay.css"],
      "js": ["browser-polyfill.min.js", "shared/content-utils.js", "content.js"],
      "run_at": "document_end"
    }
  ],
  "browser_action": {
    "default_title": "NanoGPT Browser Assistant",
    "default_icon": {
      "16": "icons/16.png",
      "32": "icons/32.png",
      "48": "icons/48.png",
      "128": "icons/128.png"
    }
  }
}
